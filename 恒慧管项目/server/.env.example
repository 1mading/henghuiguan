# -*- 正式环境配置模板 — 复制为 .env 并填写实际值 -*-

PORT=3000
HOST=0.0.0.0
NODE_ENV=production

# 生产环境务必使用随机强密钥（可用 npm run rotate-secrets 生成）
JWT_SECRET=
JWT_EXPIRES_IN=7d

DB_PATH=./data/henghuiguan.json

# ========== 钉钉开放平台 ==========
DINGTALK_CORP_ID=
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
DINGTALK_AGENT_ID=
DINGTALK_MINI_APP_ID=

# 通讯录同步起始部门 ID（逗号分隔）。仅授权部分部门时留空即可，后端会自动读取钉钉授权范围
# 若需同步财务中心等外部部门（作通知联系人），请保证授权范围或本配置覆盖这些部门
# DINGTALK_SYNC_ROOT_DEPT_IDS=123456789

# 钉钉文档知识库选择器：可选，仅展示名称包含以下关键词的知识库（逗号分隔）；留空则展示人员档案汇总结果
# DINGTALK_WIKI_WORKSPACE_KEYWORDS=信息中心

# 对外访问根地址（无末尾斜杠，示例）
# 本地作服务器: http://192.168.x.x:3000
PUBLIC_BASE_URL=http://192.168.x.x:3000

# 本地作服务器设为 true；迁移后改为 false
LOCAL_AS_SERVER=true

# 允许跨域来源（逗号分隔）
CORS_ORIGINS=http://192.168.x.x:3000,http://localhost:3000

# 正式环境必须为 false
ALLOW_DEMO_LOGIN=false

STATIC_DIR=..

# 小程序/外部 API 鉴权密钥
API_KEY=

# ========== 运维提醒（每天定时钉钉工作通知）==========
# 后端需常驻运行；仅当存在「待发版」或「未提交/未推送 Git」时发送
OPS_REMINDER_ENABLED=false
OPS_REMINDER_HOUR=16
OPS_REMINDER_MINUTE=0
# 接收人钉钉 userid（逗号分隔）。留空则尝试通知已绑定 userid 的 gm/admin
# OPS_REMINDER_DINGTALK_USER_IDS=你的钉钉userid

# ========== 绩效管理（仅一人可访问）==========
# 优先填系统用户 id（或钉钉 userid）；也可只填姓名（支持「姓名 + 空格英文名」）
# PERFORMANCE_ADMIN_USER_ID=U018
PERFORMANCE_ADMIN_USER_NAME=王元斌

# ========== 钉钉 AI 表格事项收集 ==========
# 他人填写 AI 表格表单后，自动化 HTTP 回调创建你的临时任务
INTAKE_AITABLE_ENABLED=true
INTAKE_AITABLE_API_SECRET=
INTAKE_AITABLE_ASSIGNEE_NAME=王元斌
# 可选：多人接收时逗号分隔；留空则使用 ASSIGNEE_NAME
# INTAKE_AITABLE_ASSIGNEE_NAMES=王元斌
# 单次表单最多处理附件数（默认 10）
# INTAKE_AITABLE_MAX_ATTACHMENTS=10
