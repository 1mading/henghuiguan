.page { height: 100vh; }
.center {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  height: 100vh; padding: 24px; box-sizing: border-box;
}
.tip { color: #6B7280; font-size: 14px; }
.err { color: #DC2626; font-size: 14px; margin-bottom: 16px; text-align: center; }
.hint { color: #9CA3AF; font-size: 12px; margin-top: 12px; text-align: center; }
