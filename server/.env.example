# -*- 正式环境配置模板 — 复制为 .env 并填写实际值 -*-

PORT=3000
HOST=0.0.0.0
NODE_ENV=production

# 生产环境务必使用随机强密钥（可用 npm run rotate-secrets 生成）
JWT_SECRET=
JWT_EXPIRES_IN=7d

DB_PATH=./data/henghuiguan.json

# ========== 钉钉开放平台 ==========
DINGTALK_CORP_ID=
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
DINGTALK_AGENT_ID=
DINGTALK_MINI_APP_ID=

# 通讯录同步起始部门 ID（逗号分隔）。仅授权部分部门时留空即可，后端会自动读取钉钉授权范围
# DINGTALK_SYNC_ROOT_DEPT_IDS=123456789

# 钉钉文档知识库选择器：可选，仅展示名称包含以下关键词的知识库（逗号分隔）；留空则展示人员档案汇总结果
# DINGTALK_WIKI_WORKSPACE_KEYWORDS=信息中心

# 对外访问根地址（无末尾斜杠）
# 本地作服务器: http://192.168.x.x:3000
PUBLIC_BASE_URL=http://192.168.222.26:3000

# 本地作服务器设为 true；迁移后改为 false
LOCAL_AS_SERVER=true

# 允许跨域来源（逗号分隔）
CORS_ORIGINS=http://192.168.222.26:3000,http://localhost:3000

# 正式环境必须为 false
ALLOW_DEMO_LOGIN=false

STATIC_DIR=..

# 小程序/外部 API 鉴权密钥
API_KEY=
